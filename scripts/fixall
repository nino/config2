#!/usr/bin/env bun

import { $ } from "bun";
import { existsSync } from "fs";
import { basename, dirname, join } from "path";

const ESLINT_EXTENSIONS = new Set([
  ".js",
  ".ts",
  ".tsx",
  ".jsx",
  ".mjs",
  ".cjs",
]);

function detectPackageManager(): "yarn" | "pnpm" {
  let dir = process.cwd();
  while (true) {
    if (existsSync(join(dir, "pnpm-lock.yaml"))) return "pnpm";
    if (existsSync(join(dir, "yarn.lock"))) return "yarn";
    const parent = dirname(dir);
    if (parent === dir) return "yarn";
    dir = parent;
  }
}

const pm = detectPackageManager();
console.log(`using ${pm}`);

const diffCommands: Record<string, string[]> = {
  staged: ["git", "diff", "--name-only", "--cached"],
  unstaged: ["git", "diff", "--name-only"],
  "vs origin/main": ["git", "diff", "--name-only", "origin/main..."],
};

const eslintOutput: string[] = [];

function pluralise(
  count: number,
  singular: string,
  customPlural?: string,
): string {
  const plural = customPlural ?? `${singular}s`;
  if (count === 1) return singular;
  return plural;
}

for (const [label, cmd] of Object.entries(diffCommands)) {
  const result = await $`${cmd}`.quiet().nothrow();
  const files = result
    .text()
    .split("\n")
    .filter(
      (f) =>
        f.length > 0 && existsSync(f) && basename(f) !== "pnpm-lock.yaml",
    );

  if (files.length === 0) {
    console.log(`${label}: no files`);
    continue;
  }

  const eslintFiles = files.filter((f) =>
    ESLINT_EXTENSIONS.has(f.slice(f.lastIndexOf("."))),
  );

  if (eslintFiles.length > 0) {
    console.log(
      `${label}: eslint --fix on ${eslintFiles.length} ${pluralise(eslintFiles.length, "file")}`,
    );
    const eslintResult = await $`${pm} eslint --fix ${eslintFiles}`
      .quiet()
      .nothrow();
    const output = eslintResult.text().trim();
    if (output.length > 0) {
      eslintOutput.push(output);
    }
  }

  console.log(
    `${label}: prettier --write on ${files.length} ${pluralise(files.length, "file")}`,
  );
  await $`${pm} prettier --write ${files}`.quiet().nothrow();
}

if (eslintOutput.length > 0) {
  console.log("\n--- Unresolved ESLint issues ---\n");
  console.log(eslintOutput.join("\n\n"));
}
